generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  passwordHash   String
  name           String
  school         String
  schoolType     SchoolType    @default(COLLEGE)
  createdAt      DateTime      @default(now())

  resources      Resource[]
  hostedRooms    Room[]        @relation("HostedRooms")
  playerScores   PlayerScore[]
}

enum SchoolType {
  HIGH_SCHOOL
  COLLEGE
}

model Resource {
  id             String   @id @default(uuid())
  title          String
  fileName       String
  fileUrl        String
  extractedText  String   @db.Text
  uploaderId     String
  uploader       User     @relation(fields: [uploaderId], references: [id])
  createdAt      DateTime @default(now())

  quizzes        Quiz[]
}

model Quiz {
  id             String     @id @default(uuid())
  title          String
  resourceId     String
  resource       Resource   @relation(fields: [resourceId], references: [id])
  createdAt      DateTime   @default(now())

  questions      Question[]
  rooms          Room[]
}

model Question {
  id             String   @id @default(uuid())
  quizId         String
  quiz           Quiz     @relation(fields: [quizId], references: [id])
  questionText   String
  options        Json     // stored as ["A", "B", "C", "D"]
  correctIndex   Int      // 0, 1, 2, or 3
  difficulty     String   @default("medium")
  orderIndex     Int
}

model Room {
  id              String       @id @default(uuid())
  joinCode        String       @unique
  quizId          String
  quiz            Quiz         @relation(fields: [quizId], references: [id])
  hostId          String
  host            User         @relation("HostedRooms", fields: [hostId], references: [id])
  status          RoomStatus   @default(WAITING)
  maxPlayers      Int          @default(10)
  timePerQuestion Int          @default(30)
  createdAt       DateTime     @default(now())

  playerScores    PlayerScore[]
}

enum RoomStatus {
  WAITING
  ACTIVE
  FINISHED
}

model PlayerScore {
  id             String   @id @default(uuid())
  roomId         String
  room           Room     @relation(fields: [roomId], references: [id])
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  score          Int      @default(0)
  correctAnswers Int      @default(0)
  totalAnswered  Int      @default(0)

  @@unique([roomId, userId])
}